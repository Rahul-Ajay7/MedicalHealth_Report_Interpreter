# .env.example

# APPLICATION
APP_NAME=Medical Health Report Interpreter
APP_ENV=development
DEBUG=false

# SERVER
HOST=0.0.0.0
PORT=8000

# OCR
TESSERACT_CMD=
POPPLER_PATH=
OCR_LANGUAGE=eng
OCR_PSM=6
OCR_OEM=3
PDF_DPI=300

# FILE STORAGE
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg

# SUPABASE
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# CORS
CORS_ORIGINS=http://localhost:3000

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# LLM - Ollama (backup)
LLM_BASE_URL=
LLM_CHAT_ENDPOINT=/v1/chat/completions
LLM_MODEL=healthai
LLM_TIMEOUT=120

# LLM - Groq (primary) — get key at console.groq.com
GROQ_API_KEY=

# LLM - Gemini (backup 1) — get key at aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash